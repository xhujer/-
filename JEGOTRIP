#!desc=只保留「电话/消息」和「我的」Tab，彻底屏蔽首页/社区/任务/广告/埋点
#!tag=去广告
#!icon=https://imgtolinkx.com/i/CO0eIFoS
#!openUrl=https://apps.apple.com/app/id1037589370
#!bundleId=com.cmi.jegotrip
#!date=2026-05-08

# ═══════════════════════════════════════════════════════
# 策略说明：
#   Tab 栏是客户端写死的，无法通过插件直接隐藏。
#   本插件采用「断粮」策略——屏蔽除「电话/消息」和
#   「我的」以外所有 Tab 的后端数据接口，使其打开后
#   内容为空/加载失败，实现实质性屏蔽。
#
# 保留接口（不拦截）：
#   · /api/service/user/v1/getUser          我的 - 用户信息
#   · /api/equity/v1/rights/product/details 我的 - 权益详情
#   · /api/assistant/message/recommend      电话/消息 - 客服推荐问题
#   · /api/thirdauth/getAllSsoConfig         登录认证
#
# 拦截范围：
#   · 首页 Tab：destination / banner / rec / assembly / layout
#   · 社区 Tab：socialcontact / community / content / ls
#   · 任务中心：mission / sign
#   · 开屏弹窗：assistant/alertV2
#   · 行为埋点：eventtracking / clickevent / loggw
#   · 推送角标：push.it.10086.cn
# ═══════════════════════════════════════════════════════

[Rule]
# 推送角标
DOMAIN,push.it.10086.cn,REJECT
# 阿里云 SLS 点击埋点
DOMAIN,app-product.jegotrip.com.cn,REJECT
# 支付宝 SDK 埋点
DOMAIN,loggw-exsdk.alipay.com,REJECT

[Rewrite]

# ════════════════════════
#  开屏弹窗
# ════════════════════════
^https?:\/\/app\.jegotrip\.com\.cn\/api\/assistant\/alertV2 url reject-dict

# ════════════════════════
#  【首页 Tab】完全屏蔽
# ════════════════════════
# Banner 广告
^https?:\/\/app\.jegotrip\.com\.cn\/api\/destination\/v1\/banner\/ url reject-dict
# 推荐数据 (rec/*)
^https?:\/\/app\.jegotrip\.com\.cn\/api\/destination\/v1\/rec\/ url reject-dict
# 目的地所有接口
^https?:\/\/app\.jegotrip\.com\.cn\/api\/destination\/ url reject-dict
# 楼层广告位 assembly
^https?:\/\/app\.jegotrip\.com\.cn\/api\/assembly\/ url reject-dict
# 页面布局 layout（首页/目的地）
^https?:\/\/app\.jegotrip\.com\.cn\/api\/layout\/ url reject-dict
# 全局策略
^https?:\/\/app\.jegotrip\.com\.cn\/api\/destination\/v1\/queryGlobalStrategyData url reject-dict
# 快捷入口
^https?:\/\/app\.jegotrip\.com\.cn\/api\/destination\/v1\/quickEntrance\/ url reject-dict

# ════════════════════════
#  【社区 Tab】完全屏蔽
# ════════════════════════
# 社区帖子/点赞/评论（app3）
^https?:\/\/app3\.jegotrip\.com\.cn\/api\/community\/ url reject-dict
^https?:\/\/app3\.jegotrip\.com\.cn\/api\/socialcontact\/ url reject-dict
^https?:\/\/app3\.jegotrip\.com\.cn\/api\/service\/socialcontact\/ url reject-dict
# 社区分享配置（app）
^https?:\/\/app\.jegotrip\.com\.cn\/api\/community\/ url reject-dict
# 内容流（资讯/攻略/帖子详情）
^https?:\/\/app3\.jegotrip\.com\.cn\/api\/content\/ url reject-dict
# 搜索/热搜词/相关内容
^https?:\/\/app3\.jegotrip\.com\.cn\/api\/ls\/ url reject-dict
# 行程收藏（社区相关）
^https?:\/\/app3\.jegotrip\.com\.cn\/api\/service\/agenda\/ url reject-dict
# 想去数量
^https?:\/\/app3\.jegotrip\.com\.cn\/api\/agenda\/ url reject-dict
# 社区 CDN 图片（用户上传帖子图）
^https?:\/\/cdn\.jegotrip\.com\.cn\/socialcontact\/ url reject
^https?:\/\/cdn\.jegotrip\.com\.cn\/partners\/social\/ url reject

# ════════════════════════
#  【任务中心 Tab】完全屏蔽
# ════════════════════════
^https?:\/\/app3\.jegotrip\.com\.cn\/api\/service\/v1\/mission\/ url reject-dict
^https?:\/\/cdn\.jegotrip\.com\.cn\/static\/missioncenter\/ url reject

# ════════════════════════
#  OSS 广告图片资源
# ════════════════════════
^https?:\/\/oss\.jegotrip\.com\.cn\/appSyncimage\/ url reject
^https?:\/\/oss\.jegotrip\.com\.cn\/img\/ url reject

# ════════════════════════
#  行为追踪 / 埋点
# ════════════════════════
^https?:\/\/app\.jegotrip\.com\.cn\/eventtracking\/ url reject-dict
^https?:\/\/push\.it\.10086\.cn\/mc\/receipt\/iosBadge url reject
^https?:\/\/loggw-exsdk\.alipay\.com\/ url reject

[MITM]
hostname = app.jegotrip.com.cn, app3.jegotrip.com.cn, oss.jegotrip.com.cn, cdn.jegotrip.com.cn, push.it.10086.cn, loggw-exsdk.alipay.com