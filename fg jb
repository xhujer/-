/*
 * 富贵论坛小时签到脚本（Loon 专用版）
 *
 * 作者: TimeJason（原脚本）
 * Loon 改写: ChatGPT
 * 更新日期: 2026-02-17
 *
 * 功能:
 *   - 监听网页版签到请求，自动抓取并保存账号 Cookie 及 formhash。
 *   - 定时任务每小时自动执行签到，并对结果进行通知。
 */

// ========== BoxJs Keys（与原脚本保持一致） ==========
const FUGUI_HOUR_DATA_KEY = 'fugui_hour_datas';
const KEY_NOTIFY_SUCCESS = 'fugui_hour_notify_success';
const KEY_DEBUG_LOG = 'fugui_hour_debug_log';

const SCRIPT_NAME = '富贵论坛小时签';

// ========== Loon 工具封装 ==========
function read(key) {
  return $persistentStore.read(key);
}
function write(val, key) {
  return $persistentStore.write(String(val), key);
}
function notify(title, subtitle = '', body = '') {
  $notification.post(title, subtitle, body);
}
function log(...args) {
  console.log(`[${SCRIPT_NAME}]`, ...args);
}
function done(obj = {}) {
  $done(obj);
}
function wait(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function httpGet(options) {
  return new Promise((resolve, reject) => {
    $httpClient.get(options, (error, response, data) => {
      if (error) return reject(error);
      resolve({ response, data });
    });
  });
}

// ========== 入口 ==========
(async () => {
  try {
    // Rewrite 抓数据模式：命中小时签请求
    if (typeof $request !== 'undefined' && $request.url && $request.url.includes('id=dsu_amupper&ppersubmit=true')) {
      log('进入小时签数据获取模式...');
      getAuthDataFromRequest($request);
      return done();
    }

    // Cron 模式：无 $request
    if (typeof $request === 'undefined') {
      log('进入小时签定时任务模式...');
      await runTasks();
      return done();
    }

    // 其他情况直接结束
    return done();
  } catch (e) {
    log('异常：', e && e.message ? e.message : e);
    notify(SCRIPT_NAME, '❌ 脚本异常', String(e && e.message ? e.message : e));
    return done();
  }
})();

// ========== 业务逻辑 ==========
function getFormhashFromUrl(url) {
  const match = url.match(/formhash=([a-zA-Z0-9]+)/);
  return match ? match[1] : null;
}

function getUserIdFromCookie(cookie) {
  const match = cookie.match(/JoRn_2132_auth=([^;]+)/);
  return match ? match[1].substring(0, 10) : null;
}

function safeJsonParse(str, fallback) {
  try { return JSON.parse(str); } catch { return fallback; }
}

function getAuthDataFromRequest(req) {
  const url = req.url;
  const headers = req.headers || {};
  const cookie = headers['Cookie'] || headers['cookie'];

  if (!cookie) {
    notify(SCRIPT_NAME, '❌ 获取失败', '未能读取到 Cookie。请确保在浏览器中已登录富贵论坛。');
    return;
  }

  const formhash = getFormhashFromUrl(url);
  if (!formhash) {
    notify(SCRIPT_NAME, '❌ 获取失败', '未能从URL中找到 formhash！');
    return;
  }

  const userId = getUserIdFromCookie(cookie);
  if (!userId) {
    notify(SCRIPT_NAME, '❌ 获取失败', '未能从 Cookie 中找到用户身份凭证 (auth)！');
    return;
  }

  const nickname = `网页用户_${userId}`;
  const newAccountData = { userId, nickname, cookie, formhash };

  const accountsStr = read(FUGUI_HOUR_DATA_KEY);
  const accounts = accountsStr ? safeJsonParse(accountsStr, []) : [];

  const idx = accounts.findIndex(acc => acc.userId === userId);
  if (idx > -1) {
    accounts[idx].cookie = newAccountData.cookie;
    accounts[idx].formhash = newAccountData.formhash;
    notify(SCRIPT_NAME, '✅ 配置更新成功', `账号: [${accounts[idx].nickname}]\n已更新为最新的有效配置。`);
  } else {
    accounts.push(newAccountData);
    notify(SCRIPT_NAME, '✅ 配置添加成功', `账号: [${nickname}]\n已完成初始化，你可以在 BoxJs 中修改昵称。`);
  }

  write(JSON.stringify(accounts), FUGUI_HOUR_DATA_KEY);
}

async function runTasks() {
  const accountsStr = read(FUGUI_HOUR_DATA_KEY);
  if (!accountsStr) {
    notify(SCRIPT_NAME, '❌ 未找到配置', '请先在浏览器中手动执行一次“小时签到”以初始化脚本。');
    return;
  }

  const accounts = safeJsonParse(accountsStr, []);
  if (!accounts || accounts.length === 0) {
    notify(SCRIPT_NAME, '🤔 配置为空', '没有找到任何账号信息，请先抓取数据。');
    return;
  }

  log(`共发现 ${accounts.length} 个账号，开始执行小时签任务...`);

  const summary = [];
  let allSuccessOrRepeat = true;

  for (let i = 0; i < accounts.length; i++) {
    const result = await claimReward(accounts[i]);
    if (result.includes('❌')) allSuccessOrRepeat = false;
    summary.push(result);
    if (i < accounts.length - 1) await wait(2000);
  }

  const hour = new Date().getHours();
  const finalTitle = `富贵论坛小时签 (${hour}:00)`;
  const finalMessage = summary.join('\n');

  const notifySuccess = read(KEY_NOTIFY_SUCCESS) !== 'false';

  log(`--- 任务执行摘要 ---\n${finalMessage}\n--------------------`);

  if (allSuccessOrRepeat && !notifySuccess) {
    log('✅ 所有任务执行成功或重复，根据设置不发送通知。');
  } else {
    notify(SCRIPT_NAME, finalTitle, finalMessage);
  }
}

async function claimReward(accountData) {
  const { nickname, cookie, formhash } = accountData || {};

  if (!cookie || !formhash) {
    return `👤 账号 [${nickname || '未知'}]: ❌ 缺少 Cookie 或 formhash 配置，请重新抓取。`;
  }

  const requestUrl =
    `https://www.fglt.net/plugin.php?id=dsu_amupper&ppersubmit=true&formhash=${formhash}` +
    `&infloat=yes&handlekey=dsu_amupper&inajax=1&ajaxtarget=fwin_content_dsu_amupper`;

  const options = {
    url: requestUrl,
    headers: {
      'Cookie': cookie,
      'User-Agent': 'Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.0 Mobile/15E148 Safari/604.1',
      'X-Requested-With': 'XMLHttpRequest',
      'Referer': 'https://www.fglt.net/xm_task_20130503-list.html'
    }
  };

  log(`▶️ 开始为账号 [${nickname}] 进行小时签...`);

  const debugLog = read(KEY_DEBUG_LOG) === 'true';

  try {
    const { response, data } = await httpGet(options);

    if (debugLog) {
      log(`[调试日志] 账号 [${nickname}] - 状态码: ${(response && (response.status || response.statusCode)) || 'unknown'} - 原始响应: ${data}`);
    }

    let resultSummary = `👤 账号 [${nickname}]: `;

    if (!data) {
      return resultSummary + '❌ 空响应';
    }

    if (data.includes('您已签到完毕')) {
      resultSummary += '🔁 重复签到。下个整点再来！';
    } else if (data.includes('感谢您积极打卡') || data.includes('签到成功') || data.includes('恭喜你')) {
      const match = data.match(/特奖励：(.*?)(\(|\s|$)/);
      const fallbackMatch = !match && data.match(/奖励(：|：\s*)(.*?)(\(|\s|$)/);
      const reward = match ? match[1].trim() : (fallbackMatch ? fallbackMatch[2].trim() : '奖励');
      resultSummary += `✅ 签到成功 - 获得 ${reward}`;
    } else if (data.includes('需要登录')) {
      resultSummary += '❌ 签到失败 - Cookie 已失效，请重新抓取。';
    } else {
      const failMatch = data.match(/errorhandle_dsu_amupper\('([^']+)'/);
      const failReason = failMatch ? failMatch[1] : '未知错误';
      resultSummary += `❌ 签到失败 - ${failReason}`;
    }

    return resultSummary;
  } catch (e) {
    log('请求异常：', e && e.message ? e.message : e);
    return `👤 账号 [${nickname}]: ❌ 请求异常或响应格式错误。`;
  }
}