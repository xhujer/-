/*
 * 富贵论坛小时签到脚本（Loon 原生增强版）
 *
 * 原作者: TimeJason（原脚本）
 * Loon 改写&增强: ChatGPT
 * 更新日期: 2026-02-18
 *
 * 功能:
 *   - Rewrite 抓取 Cookie & formhash
 *   - Cron 每小时签到
 *
 * 增强:
 *   A) 账号唯一键更稳：优先 *_auth=，否则 cookie hash
 *   B) 每次签到前自动刷新 formhash（失败回退旧 formhash）
 *   C) 响应解析更健壮（HTML/JS/转义/文案变动）
 *   D) Cookie 失效自动标记 + 静默降噪（默认 12 小时）
 */

// ========== BoxJs Keys ==========
const FUGUI_HOUR_DATA_KEY = "fugui_hour_datas";
const KEY_NOTIFY_SUCCESS = "fugui_hour_notify_success";
const KEY_DEBUG_LOG = "fugui_hour_debug_log";

const SCRIPT_NAME = "富贵论坛小时签";

// ========== 站点配置 ==========
const HOST = "https://www.fglt.net";
const REFRESH_FORMHASH_PAGES = [
  `${HOST}/xm_task_20130503-list.html`,
  `${HOST}/forum.php`,
  `${HOST}/`,
];

// D) 失效静默时长（小时）
const INVALID_SILENCE_HOURS = 12;

// 多账号间隔
const BETWEEN_ACCOUNTS_DELAY_MS = 2000;

// ========== Loon 原生封装 ==========
function read(key) {
  return $persistentStore.read(key);
}
function write(val, key) {
  return $persistentStore.write(String(val), key);
}
function notify(title, subtitle = "", body = "") {
  $notification.post(title, subtitle, body);
}

// ✅ 关键：单参数日志输出（避免 Loon CRON 吞多参数）
function log(...args) {
  const msg = args
    .map((v) => {
      if (v === undefined) return "undefined";
      if (v === null) return "null";
      if (typeof v === "object") {
        try {
          return JSON.stringify(v);
        } catch {
          return String(v);
        }
      }
      return String(v);
    })
    .join(" ");
  console.log(`[${SCRIPT_NAME}] ${msg}`);
}

function done(obj = {}) {
  $done(obj);
}

function wait(ms) {
  return new Promise((resolve) => setTimeout(resolve, ms));
}

function httpGet(options) {
  return new Promise((resolve, reject) => {
    $httpClient.get(options, (error, response, data) => {
      if (error) return reject(error);
      resolve({ response, data });
    });
  });
}

// ========== 入口 ==========
(async () => {
  try {
    // Rewrite 抓数据：放宽匹配
    if (
      typeof $request !== "undefined" &&
      $request.url &&
      $request.url.includes("plugin.php") &&
      $request.url.includes("id=dsu_amupper") &&
      $request.url.includes("ppersubmit=true")
    ) {
      log("进入小时签数据获取模式...");
      getAuthDataFromRequest($request);
      return done();
    }

    // Cron
    if (typeof $request === "undefined") {
      log("进入小时签定时任务模式...");
      await runTasks();
      return done();
    }

    return done();
  } catch (e) {
    log("异常：", e && e.message ? e.message : e);
    notify(SCRIPT_NAME, "❌ 脚本异常", String(e && e.message ? e.message : e));
    return done();
  }
})();

// ========== 工具 ==========
function safeJsonParse(str, fallback) {
  try {
    return JSON.parse(str);
  } catch {
    return fallback;
  }
}

function nowMs() {
  return Date.now();
}

function toInt(v, def = 0) {
  const n = parseInt(String(v), 10);
  return Number.isFinite(n) ? n : def;
}

// FNV-1a 32-bit hash（用于 cookie 缺少 auth 时生成稳定 uid）
function fnv1a32(str) {
  let h = 0x811c9dc5;
  for (let i = 0; i < str.length; i++) {
    h ^= str.charCodeAt(i);
    h = (h + (h << 1) + (h << 4) + (h << 7) + (h << 8) + (h << 24)) >>> 0;
  }
  return ("00000000" + h.toString(16)).slice(-8);
}

function getFormhashFromUrl(url) {
  const match = String(url || "").match(/(?:\?|&)formhash=([a-zA-Z0-9]+)/);
  return match ? match[1] : null;
}

// A) 不写死前缀：匹配 *_auth=xxxx
function getAuthTokenFromCookie(cookie) {
  const m = String(cookie || "").match(/(?:^|;\s*)[^=;]+_auth=([^;]+)/);
  return m ? m[1] : null;
}

function getStableUserId(cookie) {
  const auth = getAuthTokenFromCookie(cookie);
  if (auth) return auth.substring(0, 10);
  return `h_${fnv1a32(String(cookie || ""))}`;
}

function migrateAccountDefaults(acc) {
  if (!acc || typeof acc !== "object") return acc;
  if (typeof acc.invalidUntil === "undefined") acc.invalidUntil = 0;
  if (typeof acc.lastStatus === "undefined") acc.lastStatus = "";
  if (typeof acc.lastFailReason === "undefined") acc.lastFailReason = "";
  if (typeof acc.lastRunAt === "undefined") acc.lastRunAt = 0;
  return acc;
}

// ========== Rewrite 抓取 ==========
function getAuthDataFromRequest(req) {
  const url = req.url;
  const headers = req.headers || {};
  const cookie = headers["Cookie"] || headers["cookie"];

  if (!cookie) {
    notify(SCRIPT_NAME, "❌ 获取失败", "未能读取到 Cookie。请确保在浏览器中已登录富贵论坛。");
    return;
  }

  const formhash = getFormhashFromUrl(url);
  if (!formhash) {
    notify(SCRIPT_NAME, "❌ 获取失败", "未能从URL中找到 formhash（请确认命中的请求URL包含 formhash=xxxx）。");
    return;
  }

  const userId = getStableUserId(cookie);
  const nickname = `网页用户_${userId}`;

  const newAccountData = {
    userId,
    nickname,
    cookie,
    formhash,
    invalidUntil: 0,
    lastStatus: "",
    lastFailReason: "",
    lastRunAt: 0,
  };

  const accountsStr = read(FUGUI_HOUR_DATA_KEY);
  const accounts = accountsStr ? safeJsonParse(accountsStr, []) : [];

  const idx = accounts.findIndex((acc) => acc.userId === userId);
  if (idx > -1) {
    accounts[idx] = { ...migrateAccountDefaults(accounts[idx]), ...newAccountData };
    notify(SCRIPT_NAME, "✅ 配置更新成功", `账号: [${accounts[idx].nickname}]\n已更新为最新的有效配置。`);
  } else {
    accounts.push(newAccountData);
    notify(SCRIPT_NAME, "✅ 配置添加成功", `账号: [${nickname}]\n已完成初始化，你可以在 BoxJs 中修改昵称。`);
  }

  write(JSON.stringify(accounts), FUGUI_HOUR_DATA_KEY);
}

// ========== B) 刷新 formhash ==========
function extractFormhashFromHtml(html) {
  const s = String(html || "");

  let m = s.match(/name\s*=\s*["']formhash["'][^>]*value\s*=\s*["']([a-zA-Z0-9]+)["']/i);
  if (m) return m[1];

  m = s.match(/(?:\?|&)formhash=([a-zA-Z0-9]+)/i);
  if (m) return m[1];

  m = s.match(/formhash\s*[:=]\s*["']([a-zA-Z0-9]+)["']/i);
  if (m) return m[1];

  return null;
}

async function fetchFormhash(cookie) {
  const debugLog = read(KEY_DEBUG_LOG) === "true";

  for (let i = 0; i < REFRESH_FORMHASH_PAGES.length; i++) {
    const pageUrl = REFRESH_FORMHASH_PAGES[i];
    try {
      const { response, data } = await httpGet({
        url: pageUrl,
        headers: {
          Cookie: cookie,
          "User-Agent":
            "Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.0 Mobile/15E148 Safari/604.1",
          Referer: HOST,
        },
      });

      const code = (response && (response.status || response.statusCode)) || "unknown";
      const formhash = extractFormhashFromHtml(data);

      if (debugLog) log(`[调试] fetchFormhash page=${pageUrl} status=${code} formhash=${formhash || "null"}`);

      if (formhash) return formhash;
    } catch (e) {
      if (debugLog) log(`[调试] fetchFormhash page=${pageUrl} error=${e && e.message ? e.message : e}`);
    }
    await wait(300);
  }

  return null;
}

// ========== C) 响应解析增强 ==========
function stripHtml(html) {
  if (!html) return "";
  return String(html)
    .replace(/<script[\s\S]*?<\/script>/gi, " ")
    .replace(/<style[\s\S]*?<\/style>/gi, " ")
    .replace(/<[^>]+>/g, " ")
    .replace(/&nbsp;/gi, " ")
    .replace(/&amp;/gi, "&")
    .replace(/&quot;/gi, '"')
    .replace(/&#39;/gi, "'")
    .replace(/\s+/g, " ")
    .trim();
}

function parseSignResponse(raw) {
  const data = String(raw || "");
  const text = stripHtml(data);

  // 登录失效
  if (
    /需要登录|请先登录|您需要先登录|member\.php\?mod=logging|login/i.test(data) ||
    /需要登录|请先登录|登录后/i.test(text)
  ) {
    return { status: "invalid_cookie", message: "❌ 签到失败 - Cookie 已失效，请重新抓取。" };
  }

  // 重复
  if (/您已签到完毕|已签到|重复签到|already/i.test(data) || /已签到|重复/i.test(text)) {
    return { status: "repeat", message: "🔁 重复签到。下个整点再来！" };
  }

  // errorhandle
  const err = data.match(/errorhandle_dsu_amupper\('([^']+)'\)/i);
  if (err && err[1]) {
    return { status: "fail", message: `❌ 签到失败 - ${err[1]}` };
  }

  // 成功
  const successHit = /感谢|恭喜|签到成功|success/i.test(data) || /感谢|恭喜|签到成功/i.test(text);
  if (successHit) {
    let reward = null;

    let m = data.match(/特奖励[:：]\s*(.*?)(\(|\s|<|$)/);
    if (m && m[1]) reward = m[1].trim();

    if (!reward) {
      m = data.match(/奖励[:：]\s*(.*?)(\(|\s|<|$)/);
      if (m && m[1]) reward = m[1].trim();
    }

    if (!reward) reward = "奖励";

    return { status: "success", message: `✅ 签到成功 - 获得 ${reward}` };
  }

  const snippet = text ? text.slice(0, 60) : "";
  if (snippet) return { status: "fail", message: `❌ 签到失败 - ${snippet}` };

  return { status: "fail", message: "❌ 签到失败 - 未知错误" };
}

// ========== Cron 任务 ==========
async function runTasks() {
  const accountsStr = read(FUGUI_HOUR_DATA_KEY);
  if (!accountsStr) {
    notify(SCRIPT_NAME, "❌ 未找到配置", "请先在浏览器中手动执行一次“小时签到”以初始化脚本。");
    return;
  }

  let accounts = safeJsonParse(accountsStr, []);
  if (!accounts || accounts.length === 0) {
    notify(SCRIPT_NAME, "🤔 配置为空", "没有找到任何账号信息，请先抓取数据。");
    return;
  }

  accounts = accounts.map(migrateAccountDefaults);

  log(`共发现 ${accounts.length} 个账号，开始执行小时签任务...`);

  const summary = [];
  let allSuccessOrRepeat = true;
  let changed = false;

  for (let i = 0; i < accounts.length; i++) {
    const { result, updatedAccount, changed: c } = await claimReward(accounts[i]);
    summary.push(result);
    if (result.includes("❌")) allSuccessOrRepeat = false;
    accounts[i] = updatedAccount;
    if (c) changed = true;
    if (i < accounts.length - 1) await wait(BETWEEN_ACCOUNTS_DELAY_MS);
  }

  if (changed) write(JSON.stringify(accounts), FUGUI_HOUR_DATA_KEY);

  const hour = new Date().getHours();
  const finalTitle = `富贵论坛小时签 (${hour}:00)`;
  const finalMessage = summary.join("\n");

  const notifySuccess = read(KEY_NOTIFY_SUCCESS) !== "false";

  log(`--- 任务执行摘要 ---\n${finalMessage}\n--------------------`);

  if (allSuccessOrRepeat && !notifySuccess) {
    log("✅ 所有任务执行成功或重复，根据设置不发送通知。");
  } else {
    notify(SCRIPT_NAME, finalTitle, finalMessage);
  }
}

// ========== 单账号签到（A/B/C/D） ==========
async function claimReward(accountData) {
  const updated = migrateAccountDefaults({ ...(accountData || {}) });
  const debugLog = read(KEY_DEBUG_LOG) === "true";

  const { nickname, cookie } = updated;
  let { formhash } = updated;

  const prefix = `👤 账号 [${nickname || "未知"}]: `;
  const now = nowMs();

  updated.lastRunAt = now;

  if (!cookie) {
    updated.lastStatus = "fail";
    updated.lastFailReason = "缺少 Cookie";
    return { result: prefix + "❌ 缺少 Cookie 配置，请重新抓取。", updatedAccount: updated, changed: true };
  }

  // D) 失效静默期
  const invalidUntil = toInt(updated.invalidUntil, 0);
  if (invalidUntil && now < invalidUntil) {
    const leftMin = Math.max(1, Math.ceil((invalidUntil - now) / 60000));
    return {
      result: prefix + `⚠️ 已标记 Cookie 失效，静默中（约 ${leftMin} 分钟后再尝试）。请重新抓取。`,
      updatedAccount: updated,
      changed: false,
    };
  }

  // B) 刷新 formhash（失败回退）
  const refreshed = await fetchFormhash(cookie).catch(() => null);
  if (refreshed) {
    if (refreshed !== formhash) {
      formhash = refreshed;
      updated.formhash = refreshed;
    }
  }

  if (!formhash) {
    updated.lastStatus = "fail";
    updated.lastFailReason = "缺少 formhash";
    return {
      result: prefix + "❌ 缺少 formhash（请重新抓取，或确认刷新页面可获取 formhash）。",
      updatedAccount: updated,
      changed: true,
    };
  }

  const requestUrl =
    `${HOST}/plugin.php?id=dsu_amupper&ppersubmit=true&formhash=${formhash}` +
    `&infloat=yes&handlekey=dsu_amupper&inajax=1&ajaxtarget=fwin_content_dsu_amupper`;

  const options = {
    url: requestUrl,
    headers: {
      Cookie: cookie,
      "User-Agent":
        "Mozilla/5.0 (iPhone; CPU iPhone OS 16_0 like Mac OS X) AppleWebKit/605.1.15 (KHTML, like Gecko) Version/16.0 Mobile/15E148 Safari/604.1",
      "X-Requested-With": "XMLHttpRequest",
      Referer: `${HOST}/xm_task_20130503-list.html`,
    },
  };

  log(`▶️ 开始为账号 [${nickname}] 进行小时签...`);

  try {
    await wait(400);

    const { response, data } = await httpGet(options);
    const code = (response && (response.status || response.statusCode)) || "unknown";

    if (debugLog) log(`[调试日志] 账号 [${nickname}] - 状态码: ${code} - 响应片段: ${String(data || "").slice(0, 300)}`);

    if (!data) {
      updated.lastStatus = "fail";
      updated.lastFailReason = "空响应";
      return { result: prefix + "❌ 空响应", updatedAccount: updated, changed: true };
    }

    const parsed = parseSignResponse(data);

    if (parsed.status === "invalid_cookie") {
      const silenceMs = INVALID_SILENCE_HOURS * 3600 * 1000;
      updated.invalidUntil = now + silenceMs;
      updated.lastStatus = "invalid_cookie";
      updated.lastFailReason = "Cookie已失效";
      return {
        result: prefix + parsed.message + `（已静默 ${INVALID_SILENCE_HOURS} 小时，避免重复通知）`,
        updatedAccount: updated,
        changed: true,
      };
    }

    if (parsed.status === "success" || parsed.status === "repeat") {
      if (updated.invalidUntil) updated.invalidUntil = 0;
      updated.lastStatus = parsed.status;
      updated.lastFailReason = "";
      return { result: prefix + parsed.message, updatedAccount: updated, changed: true };
    }

    updated.lastStatus = "fail";
    updated.lastFailReason = parsed.message;
    return { result: prefix + parsed.message, updatedAccount: updated, changed: true };
  } catch (e) {
    log("请求异常：", e && e.message ? e.message : e);
    updated.lastStatus = "fail";
    updated.lastFailReason = "请求异常";
    return { result: prefix + "❌ 请求异常或响应格式错误。", updatedAccount: updated, changed: true };
  }
}