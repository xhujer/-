#!category=iKeLee
#!openUrl=https://apps.apple.com/app/id897003024
#!tag=去广告
#!loon_version=3.2.4(787)
#!homepage=https://hub.kelee.one
#!date=2025-05-29 00:00:00

[Rewrite]

# =========================
# 侧边栏 / 我的页面（防闪屏核心修复）
# ⚠️ 关键：不使用 del，不改变结构，只清空字段
# =========================
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ response-body-json-jq '
.data.memberOperator = {}
| .data.activityTabInfoList = []
| .data.masterOperatorList = []
| .data.extList.mineSideBanner = {}
'

# =========================
# 功能入口（仅过滤广告工具）
# =========================
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/config\/function\.do$ response-body-json-jq '
.data.config |= map(
  if .result.tools then
    .result.tools |= map(
      select(.name != "Function-AD")
    )
  else .
  end
)
'

# =========================
# 任务中心（直接空，避免UI闪回）
# =========================
^https:\/\/dashi\.163\.com\/task-center-api\/fapi\/task\/list$ response-body={}
^https:\/\/dashi\.163\.com\/task-center-api\/fapi\/task\/overview$ response-body={}

# =========================
# 运营/会员/广告接口（全部静默）
# =========================
^https:\/\/appconf\.mail\.163\.com\/mailoperating\/mailmaster\/api\/operator\/get$ response-body={}
^https:\/\/appconf\.mail\.163\.com\/mmad\/master\/get\.do$ response-body={}
^https:\/\/dashi\.163\.com\/fgw\/mail-member-center\/external\/member\/v2\/entry$ response-body={}

# =========================
# 广告配置兜底拦截
# =========================
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/http\/urlConfig\.do$ reject-dict

[MitM]
hostname = appconf.mail.163.com, dashi.163.com