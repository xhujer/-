#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/MailMaster.png
#!date=2025-05-13 15:17:08

[Rewrite]

# ======== 开屏配置 ========
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/http\/urlConfig\.do$ reject-dict

# ======== conf.do 页面配置清理 ========
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ response-body-json-del data.memberOperator data.functionOperatorInfoList data.activityTabInfoList data.masterOperatorList data.extList.mineSideBanner

^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ response-body-json-jq 'del(.data.newCommonFuncList[] | select(.strategyId == 10011))'

# ======== function.do 功能列表清理 ========
# 删除：Function-AD、Score-CardConfig、Task-Center、NPS-Config
# 删除：Hotfix-IntegralHub（邮积分卡片热更新模块）
# 侧滑工具栏只保留：邮件追踪、替身邮箱
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/config\/function\.do$ response-body-json-jq '(.data.config[] | select(.functionName == "Function-Drawer-Tools").result.tools) |= map(select(.name == "邮件追踪" or .name == "替身邮箱")) | del(.data.config[] | select(.functionName | test("^Function-(AD|Score-CardConfig|Task-Center|NPS-Config)$") or .functionName == "Hotfix-IntegralHub"))'

# ======== 邮积分数据接口（双重保险）========
^https?:\/\/dashi\.163\.com\/mailsrv-score\/ reject-dict

# ======== 任务中心 ========
^https:\/\/dashi\.163\.com\/task-center-api\/fapi\/task\/(list|overview)$ reject-dict

# ======== 运营浮层 ========
^https:\/\/appconf\.mail\.163\.com\/mailoperating\/mailmaster\/api\/operator\/get$ reject-dict

# ======== vm.mail.163.com 弹窗 & 付费引导 ========
^https:\/\/vm\.mail\.163\.com\/api\/mkt\/dialogInfo reject-dict
^https:\/\/vm\.mail\.163\.com\/api\/pay\/ reject-dict

[MitM]
hostname=appconf.mail.163.com, dashi.163.com, vm.mail.163.com