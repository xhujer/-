[Reject]
# 新增功能：预防性拦截开屏广告位
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/config\/mmad\/get\.do

[Body Rewrite]
# conf.do 部分：完全保留你原本的三行 delpaths，在下方以相同格式纯平铺追加新功能字段
http-response-jq ^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ 'delpaths([["data","functionOperatorInfoList"]])'
http-response-jq ^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ 'delpaths([["data","memberOperator"]])'
http-response-jq ^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ 'delpaths([["data","activityTabInfoList"]])'
http-response-jq ^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ 'delpaths([["data","masterOperatorList"]])'
http-response-jq ^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ 'delpaths([["data","extList","mineSideBanner"]])'
http-response-jq ^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ 'if .data.newCommonFuncList then .data.newCommonFuncList |= map(select(.strategyId != 10011)) else . end'

# function.do 部分：完全保留你原版一行的链式拼接结构，仅在 select 内部通过 or 顺延追加新功能模块
http-response-jq ^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/config\/function\.do$ '.data.config[] |= if .result.tools then .result.tools |= map(select(.name == "邮件追踪" or .name == "替身邮箱")) else . end | del(.data.config[] | select(.functionName == "Function-AD" or .functionName == "Function-Score-CardConfig" or .functionName == "Function-Task-Center" or .functionName == "Function-NPS-Config"))'

[Map Local]
# 广告落地页
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/http\/urlConfig\.do$ data-type=text data="{}" status-code=200 header="Content-Type:application/json"

# 任务列表
^https:\/\/dashi\.163\.com\/task-center-api\/fapi\/task\/list$ data-type=text data="{}" status-code=200 header="Content-Type:application/json"

# 轮播Banner + 激励广告弹窗
^https:\/\/appconf\.mail\.163\.com\/mailoperating\/mailmaster\/api\/operator\/get$ data-type=text data="{}" status-code=200 header="Content-Type:application/json"

# 新增功能：签到红点置空
^https:\/\/dashi\.163\.com\/task-center-api\/fapi\/task\/overview$ data-type=text data="{}" status-code=200 header="Content-Type:application/json"

# 新增功能：邮件追踪页会员弹窗置空
^https:\/\/vm\.mail\.163\.com\/api\/mkt\/dialogInfo$ data-type=text data="{}" status-code=200 header="Content-Type:application/json"

# 新增功能：邮件追踪页付费引导置空
^https:\/\/vm\.mail\.163\.com\/api\/pay\/ data-type=text data="{}" status-code=200 header="Content-Type:application/json"

[MITM]
# MITM 部分：纯粹平铺补全了新接口所需的 vm.mail.163.com 域名
hostname = %APPEND% appconf.mail.163.com, dashi.163.com, vm.mail.163.com
