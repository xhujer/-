#!name=网易邮箱大师净化增强版
#!desc=移除网易邮箱大师开屏广告、会员横幅、签到任务、活动推广、侧栏推广、我的页面VIP入口等。
#App链接=https://apps.apple.com/app/id897003024
#!author=ChatGPT
#!tag=去广告
#!loon_version=3.2.4(787)
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/MailMaster.png

[Rewrite]

# 开屏/动态URL配置
^https://appconf.mail.163.com/mailmaster/api/http/urlConfig.do$ reject-dict

# 首页配置（核心）
^https://appconf.mail.163.com/mailmaster/api/page/v2/conf.do$ response-body-json-jq '
del(
.data.functionOperatorInfoList,
.data.memberOperator,
.data.activityTabInfoList,
.data.vipEntrance,
.data.vipInfo,
.data.memberInfo,
.data.payGuide,
.data.banner,
.data.popup,
.data.activityList,
.data.operationList,
.data.floatLayer,
.data.redPoint
)
'

# 功能配置
^https://appconf.mail.163.com/mailmaster/api/config/function.do$ response-body-json-jq '
.data.config[] |=
if .result.tools then
.result.tools |= map(
select(
.name == "邮件追踪"
or .name == "替身邮箱"
)
)
else .
end
| del(
.data.config[]
| select(
.functionName == "Function-AD"
or .functionName == "Function-VIP"
or .functionName == "Function-Member"
)
)
'

# 任务中心
^https://dashi.163.com/task-center-api/fapi/task/list$ reject-dict

# 活动运营位
^https://appconf.mail.163.com/mailoperating/mailmaster/api/operator/get$ reject-dict

# 支付预览
^https://vm.mail.163.com/api/pay/initPreview$ reject-dict

# 用户会员信息（核心）
^https://vm.mail.163.com/api/user/info/detail3$ response-body-json-jq '
.data.mbrType = 0
| .data.memberBanner = null
| .data.vipInfo = null
| .data.payInfo = null
| .data.memberInfo = null
| .data.activityInfo = null
'

# 红点/提醒
^https://.(red|badge|dot|remind). url reject-dict

[MitM]
hostname=appconf.mail.163.com,dashi.163.com,vm.mail.163.com