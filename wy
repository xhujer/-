[Rewrite]

# ======== 强制明文：去掉 Accept-Encoding，让服务器返回未压缩 JSON ========
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ request-header {\r\nAccept-Encoding: gzip, deflate, br\r\n} {\r\nAccept-Encoding: identity\r\n}

^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/config\/function\.do$ request-header {\r\nAccept-Encoding: gzip, deflate, br\r\n} {\r\nAccept-Encoding: identity\r\n}

# ======== 开屏配置 ========
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/http\/urlConfig\.do$ reject-dict

# ======== conf.do 页面配置清理 ========
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ response-body-json-del data.memberOperator data.functionOperatorInfoList data.activityTabInfoList data.masterOperatorList data.extList.mineSideBanner

^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ response-body-json-jq 'del(.data.newCommonFuncList[] | select(.strategyId == 10005 or .strategyId == 10006 or .strategyId == 10007 or .strategyId == 10010 or .strategyId == 10011))'

# ======== function.do 功能列表清理 ========
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/config\/function\.do$ response-body-json-jq 'del(.data.config[] | select(.functionName | test("^Function-(AD|Score-CardConfig|Task-Center|NPS-Config|Drawer-Tools)$") or . == "Hotfix-IntegralHub"))'

# ======== 邮积分数据接口 ========
^https?:\/\/dashi\.163\.com\/mailsrv-score\/ reject-dict

# ======== 任务中心 ========
^https:\/\/dashi\.163\.com\/task-center-api\/fapi\/task\/(list|overview)$ reject-dict

# ======== 运营浮层 ========
^https:\/\/appconf\.mail\.163\.com\/mailoperating\/mailmaster\/api\/operator\/get$ reject-dict

# ======== vm.mail.163.com 弹窗 & 付费引导 ========
^https:\/\/vm\.mail\.163\.com\/api\/mkt\/dialogInfo reject-dict
^https:\/\/vm\.mail\.163\.com\/api\/pay\/ reject-dict

[MitM]
hostname=appconf.mail.163.com, dashi.163.com, vm.mail.163.com
