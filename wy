#!name=163Mail_Rewarded_Unlock
#!desc=网易邮箱 看视频扩容/会员奖励增强
#!author=fixed
#!homepage=https://mail.163.com
#!system=ios

[MITM]
hostname = mail.163.com, appconf.mail.163.com, dashi.163.com

[Rewrite]
# 任务次数
^https:\/\/appconf\.mail\.163\.com\/mmad-rewarded\/fapi\/task\/list url response-body "dailyRemainingCnt\":\d+" "dailyRemainingCnt\":99"
^https:\/\/appconf\.mail\.163\.com\/mmad-rewarded\/fapi\/task\/list url response-body "remainingCnt\":\d+" "remainingCnt\":99"
^https:\/\/appconf\.mail\.163\.com\/mmad-rewarded\/fapi\/task\/list url response-body "dailyObtainedCnt\":\d+" "dailyObtainedCnt\":0"

# 广告已观看（修正：替换值改为false→true）
^https:\/\/mail\.163\.com\/fgw\/mail-member-center\/external\/rights url response-body "\"watched\":false" "\"watched\":true"

# AI余额
^https:\/\/mail\.163\.com\/fgw\/mail-member-center\/external\/privilege\/data url response-body "\"aiAssistantBalance\":\d+" "\"aiAssistantBalance\":9999"

# 容量
^https:\/\/mail\.163\.com\/fgw\/mail-member-center\/external\/privilege\/data url response-body "\"total\":\d+" "\"total\":1099511627776"
^https:\/\/mail\.163\.com\/fgw\/mail-member-center\/external\/privilege\/data url response-body "\"used\":\d+" "\"used\":0"
