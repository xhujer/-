#!name=网易邮箱大师去广告
#!desc=移除网易邮箱大师开屏广告、签到任务提醒、会员推广入口，精简侧拉抽屉和我的页面。
#App链接=https://apps.apple.com/app/id897003024
#!author=可莉🅥 + ChatGPT
#!tag=去广告
#!system=
#!system_version=
#!loon_version=3.2.4(787)
#!homepage=https://github.com/Moli-X/Tool/raw/X/Loon/Plugin/Kelee/MailMaster_remove_ads.plugin
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/MailMaster.png
#!date=2025-05-13 15:17:08

[Rewrite]
# URL动态配置
^https://appconf.mail.163.com/mailmaster/api/http/urlConfig.do$ reject-dict

# 页面配置
^https://appconf.mail.163.com/mailmaster/api/page/v2/conf.do$ response-body-json-del data.functionOperatorInfoList data.memberOperator data.activityTabInfoList

# 功能入口（仅保留核心）
^https://appconf.mail.163.com/mailmaster/api/config/function.do$ response-body-json-jq '.data.config[] |= if .result.tools then .result.tools |= map(select(.name == "邮件追踪" or .name == "替身邮箱")) else . end | del(.data.config[] | select(.functionName == "Function-AD"))'

# 任务中心
^https://dashi.163.com/task-center-api/fapi/task/list$ reject-dict

# 活动运营位
^https://appconf.mail.163.com/mailoperating/mailmaster/api/operator/get$ reject-dict

# 用户会员信息（去除开通大师会员）
^https://vm.mail.163.com/api/user/info/detail3$ response-body-json-jq '.data.mbrType=0 | .data.memberBanner=null | .data.vipInfo=null | .data.memberInfo=null | .data.payInfo=null | .data.activityInfo=null'

# 会员中心入口
^https://mail.163.com/fgw/mail-member-center/external/member/v2/entry$ reject-dict

# 会员购买页
^https://vm.mail.163.com/api/pay/initPreview$ reject-dict

[MitM]
hostname=appconf.mail.163.com, dashi.163.com, vm.mail.163.com, mail.163.com