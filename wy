#!name=网易邮箱大师去广告
#!desc=移除网易邮箱大师开屏广告、签到任务提醒，精简侧拉抽屉和我的页面。
#App链接=https://apps.apple.com/app/id897003024
#!author=可莉🅥[https://github.com/Moli-X/Tool/blob/X/Loon/Readme.md]
#!tag=去广告
#!system=
#!system_version=
#!loon_version=3.2.4(787)
#!homepage=https://github.com/Moli-X/Tool/raw/X/Loon/Plugin/Kelee/MailMaster_remove_ads.plugin
#!icon=https://raw.githubusercontent.com/luestr/IconResource/main/App_icon/120px/MailMaster.png
#!date=2025-05-13 15:17:08

[Rewrite]
# 预防性拦截开屏广告位
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/config\/mmad\/get\.do reject-dict

# 广告落地页
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/http\/urlConfig\.do$ reject-dict

# 我的页面配置精简：将原有的 json-del 直接改为安全的单行 jq，合并剔除原有 3 字段、新广告卡片、新会员横幅，并安全过滤 AI 工具箱
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/page\/v2\/conf\.do$ response-body-json-jq 'del(.data.functionOperatorInfoList, .data.memberOperator, .data.activityTabInfoList, .data.masterOperatorList, .data.extList.mineSideBanner) | if .data.newCommonFuncList then .data.newCommonFuncList |= map(select(.strategyId != 10011)) else . end'

# 功能配置精简：100% 保留你原版的长公式结构，仅在最后的 select 内部通过 or 顺延追加新功能模块
^https:\/\/appconf\.mail\.163\.com\/mailmaster\/api\/config\/function\.do$ response-body-json-jq '.data.config[] |= if .result.tools then .result.tools |= map(select(.name == "邮件追踪" or .name == "替身邮箱")) else . end | del(.data.config[] | select(.functionName == "Function-AD" or .functionName == "Function-Score-CardConfig" or .functionName == "Function-Task-Center" or .functionName == "Function-NPS-Config"))'

# 任务列表
^https:\/\/dashi\.163\.com\/task-center-api\/fapi\/task\/list$ reject-dict

# 轮播Banner + 激励广告弹窗
^https:\/\/appconf\.mail\.163\.com\/mailoperating\/mailmaster\/api\/operator\/get$ reject-dict

# 新增功能：签到红点置空
^https:\/\/dashi\.163\.com\/task-center-api\/fapi\/task\/overview$ reject-dict

# 新增功能：邮件追踪页会员弹窗置空
^https:\/\/vm\.mail\.163\.com\/api\/mkt\/dialogInfo$ reject-dict

# 新增功能：邮件追踪页付费引导置空
^https:\/\/vm\.mail\.163\.com\/api\/pay\/ reject-dict

[MitM]
hostname=appconf.mail.163.com, dashi.163.com, vm.mail.163.com
