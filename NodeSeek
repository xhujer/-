#!name=NodeSeek 自动签到
#!desc=自动抓取Cookie并定时签到
#!author=ming
#!icon=https://www.nodeseek.com/favicon.ico
#!homepage=https://www.nodeseek.com/

[Argument]
RunTime = input,"0 6 * * *",tag=每日签到时间
CaptureCookie = switch,true,tag=自动获取Cookie
Random = switch,true,tag=随机签到

[Script]
cron {RunTime} script-path=https://raw.githubusercontent.com/xhujer/-/refs/heads/main/NodeSeek.js, tag=NodeSeek签到, timeout=60, script-update-interval=86400, argument=Random={Random}

http-request ^https?:\/\/(?:www\.)?nodeseek\.com\/ script-path=https://raw.githubusercontent.com/xhujer/-/refs/heads/main/NodeSeek.js, tag=NodeSeek抓Cookie, timeout=10, requires-body=false, enabled={CaptureCookie}, script-update-interval=86400

[Mitm]
hostname = nodeseek.com, www.nodeseek.com