    root.innerHTML = `
      <div class="fg-panel">
        <div class="fg-header">
          <div class="fg-title">${ICONS.edit} 挑选回复</div>
          <div class="fg-refresh-btn" title="换一批">${ICONS.refresh}</div>
        </div>
        <div class="fg-tags-container" id="fg-tags-list"></div>
        <button class="fg-action-btn" id="fg-random-send">${ICONS.lightning} 一键随机发送</button>
      </div>
      <div class="fg-float-ball" title="拖动 / 点击">${ICONS.chat}</div>
    `;

