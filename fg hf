    const handleDrag = el => {
      let startX, startY, initialRight, initialBottom;

      const onStart = (cx, cy) => {
        isDragging = false;

        const style = window.getComputedStyle(el);

        startX = cx;
        startY = cy;
        initialRight = parseInt(style.right, 10) || 0;
        initialBottom = parseInt(style.bottom, 10) || 0;

        document.addEventListener("mousemove", onMove);
        document.addEventListener("mouseup", onEnd);
        document.addEventListener("touchmove", onTouchMove, { passive: false });
        document.addEventListener("touchend", onEnd);
      };

      const moveLogic = (cx, cy) => {
        const dx = startX - cx;
        const dy = startY - cy;

        if (Math.abs(dx) > 3 || Math.abs(dy) > 3) isDragging = true;

        el.style.right = `${initialRight + dx}px`;
        el.style.bottom = `${initialBottom + dy}px`;
      };

      const onMove = e => {
        moveLogic(e.clientX, e.clientY);
      };

      const onTouchMove = e => {
        e.preventDefault();
        moveLogic(e.touches[0].clientX, e.touches[0].clientY);
      };

      const onEnd = () => {
        document.removeEventListener("mousemove", onMove);
        document.removeEventListener("mouseup", onEnd);
        document.removeEventListener("touchmove", onTouchMove);
        document.removeEventListener("touchend", onEnd);

        GM_setValue(
          KEY_FLOAT_POS,
          JSON.stringify({
            right: el.style.right,
            bottom: el.style.bottom,
          })
        );
      };

      el.addEventListener("mousedown", e => onStart(e.clientX, e.clientY));

      el.addEventListener(
        "touchstart",
        e => onStart(e.touches[0].clientX, e.touches[0].clientY),
        { passive: false }
      );
    };

    handleDrag(root);

    document.addEventListener("click", e => {
      if (!root.contains(e.target)) {
        panel.classList.remove("active");
        ball.style.transform = "";
        ball.style.boxShadow = "";
      }
    });
  }

  // ===================== 油猴菜单 =====================
  GM_registerMenuCommand("立即签到", doSignOnce);

  // ===================== 兼容页面跳转 / 局部刷新 =====================
  let refreshTimer = null;

  function scheduleRefreshReplyWidget() {
    clearTimeout(refreshTimer);
    refreshTimer = setTimeout(refreshReplyWidgetVisible, 300);
  }

  const oldPushState = history.pushState;
  const oldReplaceState = history.replaceState;

  history.pushState = function (...args) {
    const ret = oldPushState.apply(this, args);
    scheduleRefreshReplyWidget();
    return ret;
  };

  history.replaceState = function (...args) {
    const ret = oldReplaceState.apply(this, args);
    scheduleRefreshReplyWidget();
    return ret;
  };

  window.addEventListener("popstate", scheduleRefreshReplyWidget);

  const pageObserver = new MutationObserver(scheduleRefreshReplyWidget);

  pageObserver.observe(document.documentElement, {
    childList: true,
    subtree: true,
  });

  // ===================== 启动 =====================
  setTimeout(runOncePerDay, 1000);
  refreshReplyWidgetVisible();

})();