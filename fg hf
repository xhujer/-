      if (isDragging) return;

      panel.classList.toggle("active");

      if (panel.classList.contains("active")) {
        ball.style.transform = "scale(1.02)";
        ball.style.boxShadow = "0 0 0 8px rgba(0, 122, 255, 0.3)";
