  // ===================== 快捷回复工具 =====================
  const Utils = {
    getBatch(count = 5) {
      return [...replyLib].sort(() => 0.5 - Math.random()).slice(0, count);
    },

    getByteLength(str) {
      let len = 0;
      for (let i = 0; i < str.length; i++) {
        len += str.charCodeAt(i) > 255 ? 3 : 1;
      }
      return len;
    },

    toast(msg, type = "info") {
      let el = document.getElementById("fg-toast");

      if (!el) {
        el = document.createElement("div");
        el.id = "fg-toast";
        document.body.appendChild(el);
      }

      let icon = type === "success"
        ? '<svg viewBox="0 0 24 24" style="width:32px;height:32px;fill:#2ecc71"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>'
        : '<svg viewBox="0 0 24 24" style="width:32px;height:32px;fill:#3498db"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/></svg>';

      if (type === "error") {
        icon = '<svg viewBox="0 0 24 24" style="width:32px;height:32px;fill:#e74c3c"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-2h2v2zm0-4h-2V7h2v6z"/></svg>';
      }

      el.innerHTML = `${icon}<span>${msg}</span>`;

      requestAnimationFrame(() => {
        el.classList.add("show");
      });

      if (window.fgToastTimer) clearTimeout(window.fgToastTimer);

      window.fgToastTimer = setTimeout(() => {
        el.classList.remove("show");
      }, 2500);
    },

    getPostElements() {
      return {
        box: document.getElementById("fastpostmessage"),
        btn: document.getElementById("fastpostsubmit"),
      };
    }
  };

  // ===================== 判断是否为帖子详情页 =====================
  function isThreadPage() {
    const path = location.pathname;
    const search = location.search;

    // Discuz 动态帖子页：forum.php?mod=viewthread&tid=xxx
    if (/\/forum\.php/i.test(path) && /(?:^|[?&])mod=viewthread(?:&|$)/i.test(search)) {
      return true;
    }

    // Discuz 伪静态帖子页：thread-123-1-1.html
    if (/\/thread-\d+-\d+-\d+\.html/i.test(path)) {
      return true;
    }

    // DOM 兜底：有帖子内容区 + 快速回复框
    if (document.querySelector("#postlist") && document.getElementById("fastpostmessage")) {
      return true;
    }

    return false;
  }

  function removeReplyWidget() {
    const root = document.getElementById("fg-widget-root");
    if (root) root.remove();
  }

  function refreshReplyWidgetVisible() {
    if (isThreadPage()) {
      initUI();
    } else {
      removeReplyWidget();
    }
  }

  // ===================== 签到网络请求 =====================
  function httpRequest(method, url, referer) {
    return new Promise((resolve, reject) => {
      GM_xmlhttpRequest({
        method,
        url,
        withCredentials: true,
        headers: {
          "User-Agent": "Mozilla/5.0",
          ...(referer ? { Referer: referer } : {}),
        },
        onload: res => resolve(res.responseText || ""),
        onerror: reject,
        ontimeout: () => reject(new Error("timeout")),
        timeout: 30000,
      });
    });
  }

  async function getFormhash() {
    const html = await httpRequest("POST", rules.url1);
    const m = html.match(rules.regFormhash);
    return m?.[1];
  }

  async function doSignOnce() {
    try {
      const formhash = await getFormhash();

      if (!formhash) {
        signNotify("未获取到 formhash");
        return;
      }

      const url = rules.signUrlTpl.replace("@formhash", formhash);
      const ret = await httpRequest("POST", url, rules.url1);

      let msg = "异常";
      if (rules.regDup.test(ret)) msg = "已签到";
      else if (rules.regOk.test(ret)) msg = "签到成功";

      signNotify(msg);
    } catch {
      signNotify("签到失败");
    }
  }

  function runOncePerDay() {
    if (GM_getValue(KEY_LAST_RUN_DATE, "") === todayStr()) return;
    GM_setValue(KEY_LAST_RUN_DATE, todayStr());
    doSignOnce();
  }

  // ===================== 快捷回复发送 =====================
  function submitReply(text) {
    const { box, btn } = Utils.getPostElements();

    if (!box || !btn) {
      Utils.toast("未找到回复框 (请先登录)", "error");
      return;
    }

    let finalText = text;
    const TARGET_BYTES = 20;
    const NBSP = "\u00A0";

    while (Utils.getByteLength(finalText) < TARGET_BYTES) {
      finalText += NBSP;
    }

    box.value = finalText;

    box.dispatchEvent(new Event("input", { bubbles: true }));
    box.dispatchEvent(new Event("change", { bubbles: true }));

    box.style.transition = "background 0.3s";
    box.style.backgroundColor = "rgba(0, 122, 255, 0.1)";

    setTimeout(() => {
      box.style.backgroundColor = "";
    }, 300);

    Utils.toast("正在发送...");

    setTimeout(() => {
      btn.click();

      const panel = document.querySelector(".fg-panel");
      if (panel) panel.classList.remove("active");

      Utils.toast("发送成功", "success");
    }, 500);
  }

  // ===================== 快捷回复 UI =====================
