    const tagsList = root.querySelector("#fg-tags-list");
    const refreshBtn = root.querySelector(".fg-refresh-btn");
    const randomBtn = root.querySelector("#fg-random-send");

    const renderTags = () => {
      tagsList.innerHTML = "";

      Utils.getBatch(6).forEach(text => {
        const tag = document.createElement("div");
        tag.className = "fg-tag";
        tag.innerText = text;
        tag.onclick = () => submitReply(text);
        tagsList.appendChild(tag);
