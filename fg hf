  // ===================== 签到 Toast（原顶部状态条） =====================
  let signWrap = null;
  let signInner = null;
  let signHideTimer = null;
  let signRemoveTimer = null;

  function signNotify(text) {
    clearTimeout(signHideTimer);
    clearTimeout(signRemoveTimer);

    if (!signWrap || !signInner || !document.body.contains(signWrap)) {
      signWrap?.remove();

      signWrap = document.createElement("div");
      signWrap.style.cssText = `
        position: fixed;
        top: 0;
        left: 0;
        width: 100%;
        z-index: 9999999;
        pointer-events: none;
      `;

      signInner = document.createElement("div");
      signInner.style.cssText = `
        width: 100%;
        padding: 10px 0;
        text-align: center;
        font-size: 14px;
        font-weight: 500;
        color: rgba(255,255,255,0.95);
        background: #4D82D6;
        transform: translateY(-100%);
        opacity: 0;
        transition: transform 220ms ease, opacity 220ms ease;
        will-change: transform, opacity;
      `;

      signWrap.appendChild(signInner);
      document.body.appendChild(signWrap);
    }

    let bg = "#4D82D6";
    if (/成功/.test(text)) bg = "#57BF57";
    else if (/失败|异常/.test(text)) bg = "#E1715B";
    else if (/未登录|已签到|未获取/.test(text)) bg = "#D6A14D";

    signInner.textContent = `签到 · ${text}`;
    signInner.style.background = bg;

    signInner.style.transition = "none";
    signInner.style.transform = "translateY(-100%)";
    signInner.style.opacity = "0";
    void signInner.offsetHeight;

    requestAnimationFrame(() => {
      if (!signInner) return;
      signInner.style.transition = "transform 220ms ease, opacity 220ms ease";
      signInner.style.transform = "translateY(0)";
      signInner.style.opacity = "1";
    });

    signHideTimer = setTimeout(() => {
      if (!signInner) return;
      signInner.style.transform = "translateY(-100%)";
      signInner.style.opacity = "0";
    }, 1400);

    signRemoveTimer = setTimeout(() => {
      signWrap?.remove();
      signWrap = null;
      signInner = null;
    }, 2500);
  }

  // ===================== 快捷回复样式（原 V5.6 风格） =====================
