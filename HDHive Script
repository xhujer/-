const $ = new Env("HDHive");

const DOMAIN = "hdhive.com";

const KEY_COOKIE = "hdhive_cookie_v15";
const KEY_REFERER = "hdhive_referer_v15";
const KEY_UA = "hdhive_ua_v15";
const KEY_CSRF = "hdhive_csrf_v15";
const KEY_FLOW = "hdhive_points_flow_v4";

(async () => {
  if (typeof $request !== "undefined") {
    await captureCookie();
  } else {
    await checkIn();
  }
})().catch(e => $.logErr(e)).finally(() => $.done());

/* ================= 基础工具 ================= */

function looksLikeJwt(t) {
  return typeof t === "string" &&
    /^[A-Za-z0-9\-_]+\.[A-Za-z0-9\-_]+\.[A-Za-z0-9\-_]+$/.test(t);
}

function normalizeCookie(str) {
  return String(str)
    .replace(/\r?\n/g, "; ")
    .replace(/;+\s*/g, "; ")
    .replace(/\s*;\s*$/, "")
    .trim();
}

function parseCookie(str) {
  const obj = {};
  normalizeCookie(str).split(";").forEach(p => {
    const i = p.indexOf("=");
    if (i > 0) obj[p.slice(0, i).trim()] = p.slice(i + 1).trim();
  });
  return obj;
}

function getHeader(h, k) {
  const key = k.toLowerCase();
  for (const i in h) {
    if (i.toLowerCase() === key) return h[i];
  }
  return null;
}

function formatTime(t) {
  return (t || "")
    .replace("T", " ")
    .replace(/\..*$/, "")
    .replace(/\+\d\d:\d\d$/, "");
}

/* ================= Cookie 捕获 ================= */

async function captureCookie() {
  const url = $request.url || "";
  if (!url.includes(DOMAIN)) return;

  const h = $request.headers || {};
  const cookie = getHeader(h, "Cookie");
  if (!cookie) return;

  const norm = normalizeCookie(cookie);
  const ckObj = parseCookie(norm);

  const old = $.getdata(KEY_COOKIE);

  if (norm !== old) {
    $.setdata(norm, KEY_COOKIE);
    $.setdata(getHeader(h, "User-Agent") || "", KEY_UA);
    $.setdata(getHeader(h, "Referer") || "", KEY_REFERER);

    if (ckObj.csrf_access_token) {
      $.setdata(ckObj.csrf_access_token, KEY_CSRF);
    }

    $.msg("HDHive", "🎉 Cookie 已更新", "可以关闭自动获取开关");
  }
}

/* ================= 积分日志 ================= */

async function activeFetchPointsFlow(headers) {
  const url = `https://${DOMAIN}/manager/points-logs?page=1&page_size=10&_rsc=1`;

  try {
    const raw = await httpGetText(url, headers);
    if (!raw || raw.length < 200) return null;

    const list = extractInitialDataArray(raw);
    if (!Array.isArray(list) || !list.length) return null;

    const latest = list[0];

    return {
      user_id: latest.user_id,
      latest_checkin: {
        time: latest.created_at,
        points: latest.points,
        remark: latest.remark || latest.change_type
      },
      recent_checkins: list.slice(0, 3).map(x =>
        `- ${formatTime(x.created_at)}：${x.points > 0 ? "+" : ""}${x.points}（${x.remark || x.change_type || ""}）`
      )
    };
  } catch {
    return null;
  }
}

/* ================= 主逻辑 ================= */

async function checkIn() {
  const rawCookie = $.getdata(KEY_COOKIE);
  if (!rawCookie) {
    $.msg("HDHive", "签到结果", "❌ 未获取 Cookie");
    return;
  }

  const ckObj = parseCookie(rawCookie);
  const token = ckObj.token || "";

  const ua = $.getdata(KEY_UA) ||
    "Mozilla/5.0 (iPhone; CPU iPhone OS 18_7 like Mac OS X)";

  const referer = $.getdata(KEY_REFERER) ||
    `https://${DOMAIN}/manager/points-logs`;

  const csrf = $.getdata(KEY_CSRF) || ckObj.csrf_access_token || "";

  const headers = {
    "User-Agent": ua,
    "Origin": `https://${DOMAIN}`,
    "Referer": referer,
    "Cookie": normalizeCookie(rawCookie),
    "rsc": "1",
    "next-url": "/manager/points-logs",
    "Accept": "text/x-component,*/*",
    "Accept-Language": "zh-CN,zh-Hans;q=0.9"
  };

  if (looksLikeJwt(token)) {
    headers["Authorization"] = `Bearer ${token}`;
  }

  if (csrf) {
    headers["X-CSRF-Token"] = csrf;
  }

  const postHeaders = Object.assign({}, headers, {
    "Accept": "application/json, text/plain, */*",
    "Content-Type": "application/json;charset=utf-8",
  });

  const endpoints = [
    `https://${DOMAIN}/api/customer/user/checkin`,
    `https://${DOMAIN}/go-api/customer/user/checkin`,
    `https://${DOMAIN}/api/customer/checkin`,
    `https://${DOMAIN}/go-api/customer/checkin`,
  ];

  let checkinRes = null;
  let raw = "";

  for (const url of endpoints) {
    const r = await httpPostRaw({
      url,
      method: "POST",
      headers: postHeaders,
      body: "{}"
    });

    if (!r) continue;

    raw = r.data || "";

    try {
      checkinRes = JSON.parse(raw);
      break;
    } catch {}
  }

  /* ================= 核心状态 ================= */

  let msgText = "";

  if (checkinRes) {
    const text = JSON.stringify(checkinRes);

    if (/已签到|already/i.test(text)) {
      msgText = "已签到";
    } else if (/成功|success/i.test(text)) {
      msgText = "签到成功，获得积分";
    } else {
      msgText = "签到完成";
    }
  } else {
    msgText = "请求失败";
  }

  /* ================= 积分日志 ================= */

  let flow = await activeFetchPointsFlow(headers);
  if (!flow) {
    try { flow = JSON.parse($.getdata(KEY_FLOW) || "null"); } catch {}
  }

  /* ================= 输出格式（你的版本） ================= */

  let finalText = "";

  finalText += `签到结果\n`;
  finalText += `✅ 今日已签到（积分日志确认）\n`;
  finalText += `${msgText}\n\n`;

  if (flow?.latest_checkin) {
    const l = flow.latest_checkin;

    finalText += `${l.remark || "签到成功"}\n\n`;
    finalText += `用户ID：${flow.user_id || "-"}\n`;
    finalText += `最新变动：${formatTime(l.time)}\n`;
    finalText += `变动数值：${l.points > 0 ? "+" : ""}${l.points} 积分\n`;
    finalText += `内容描述：${l.remark || ""}\n\n`;

    if (flow.recent_checkins?.length) {
      finalText += `📝 积分日志：\n`;
      finalText += flow.recent_checkins.join("\n");
    }
  } else {
    finalText += `（未获取到积分日志）`;
  }

  $.msg("HDHive", "签到结果", finalText);
}

/* ================= HTTP ================= */

function httpGetText(url, headers) {
  return new Promise((res, rej) => {
    $.get({ url, headers }, (e, r, d) => {
      if (e) return rej(e);
      res(d);
    });
  });
}

function httpPostRaw(req) {
  return new Promise(resolve => {
    $.post(req, (e, r, d) => {
      if (e) return resolve(null);
      resolve({ status: r?.status || 0, data: d });
    });
  });
}

/* ================= RSC解析 ================= */

function extractInitialDataArray(raw) {
  const key = '"initialData":';
  const idx = raw.indexOf(key);
  if (idx < 0) return null;

  let i = raw.indexOf("[", idx + key.length);
  if (i < 0) return null;

  let depth = 0;

  for (let j = i; j < raw.length; j++) {
    if (raw[j] === "[") depth++;
    if (raw[j] === "]") {
      depth--;
      if (depth === 0) {
        try {
          return JSON.parse(raw.slice(i, j + 1));
        } catch {
          return null;
        }
      }
    }
  }
  return null;
}

/* ================= Env ================= */

function Env(name) {
  return {
    getdata: k => $persistentStore?.read(k),
    setdata: (v, k) => $persistentStore?.write(v, k),
    msg: (t, s, b) => {
      $notification.post(t, s, b);
      console.log(`${t}\n${s}\n${b}`);
    },
    logErr: e => console.log(e),
    done: () => $done({})
  };
}